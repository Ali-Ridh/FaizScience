# 1. Define vectors for the first dataframe
gender <- c("Female", "Male", "Male", "Female", "Male")
height <- c(160, 175, 173, 156, 169)
weight <- c(49, 89, 77, 56, 81)
age    <- c(35, 36, 41, 23, 28)
names  <- c("Carrol", "Mike", "John", "Suuria", "Malik")

# Create the first dataframe (df1)
df1 <- data.frame(names, gender, height, weight, age)

# 2. Define vectors for the second dataframe
states      <- c("Selangor", "Perak", "Melaka")
names_state <- c("Carrol", "John", "Malik")

# Create the second dataframe (df2)
df2 <- data.frame(names = names_state, states)

# 3. Perform a Full Outer Join
# 'all = TRUE' ensures all records from both datasets are kept
dfMerge <- merge(df1, df2, by = "names", all = TRUE)

# View the final merged dataset
print(dfMerge)

