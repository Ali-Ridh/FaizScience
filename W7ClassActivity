# Effect of Missing Values

# A missing value in the dataset is represented as NA
# NAs have to be handled in the dataset because of the following:

# creating a vector of integers having NAs.
a <- c(1:5, rep(NA, 3), 6:10)
a

# performing sum on the vector
sum(a)

# selecting only integer values
b <- a[!is.na(a)]
b

# performing sum on the new vector
sum(b)

